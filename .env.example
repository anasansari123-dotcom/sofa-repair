# MongoDB Atlas (production / local)
# Format: mongodb+srv://USER:PASS@cluster.../DATABASE?options
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/tanseer?retryWrites=true&w=majority

# Admin panel (REQUIRED on Vercel — use a strong password + long secret)
ADMIN_PASSWORD=change-this-password
ADMIN_SECRET=change-this-to-a-long-random-string
