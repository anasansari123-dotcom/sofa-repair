# Local MongoDB (dev only)
MONGODB_URI=mongodb://localhost:27017/tanseer

# Vercel: use MongoDB Atlas, e.g.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/tanseer?retryWrites=true&w=majority

# Admin panel credentials (REQUIRED on Vercel)
ADMIN_PASSWORD=change-this-password
ADMIN_SECRET=change-this-to-a-long-random-string

# Not used by this project (custom cookie auth, not NextAuth):
# NEXTAUTH_URL=
# NEXTAUTH_SECRET=
